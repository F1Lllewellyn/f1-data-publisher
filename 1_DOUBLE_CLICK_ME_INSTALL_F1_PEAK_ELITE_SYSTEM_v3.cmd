@echo off
setlocal EnableExtensions
cd /d "%~dp0"
title F1 Peak-Elite System Installer v3 - Single Click
color 0A

echo ============================================================
echo  F1 PEAK-ELITE SYSTEM INSTALLER v3 - SINGLE CLICK
echo ============================================================
echo.
echo This version is self-contained. It does not depend on a sibling .ps1 file.
echo It can recover from the Windows compressed-folder issue you just hit.
echo.
echo Target repo:
echo   C:\Users\Matt Llewellyn\OneDrive\Documents\GitHub\f1-data-publisher
echo.
echo It will NOT modify Engine_2026-06-07_STABLE, canonical workbooks,
echo prediction model logic, or promotion state.
echo.
pause

set "WORKROOT=%TEMP%\F1_PeakElite_Installer_v3_%RANDOM%%RANDOM%"
echo.
echo Running self-contained installer now...
echo Work folder: %WORKROOT%
echo.
powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -EncodedCommand  "%~f0" "%WORKROOT%"
set EXITCODE=%ERRORLEVEL%

echo.
echo ============================================================
echo  Installer finished with exit code: %EXITCODE%
echo ============================================================
echo.
if exist "%TEMP%\F1_PEAK_ELITE_INSTALL_REPORT_LAST_RUN.txt" (
  echo Opening install report...
  start "" notepad "%TEMP%\F1_PEAK_ELITE_INSTALL_REPORT_LAST_RUN.txt"
) else (
  echo No install report was created. The installer likely stopped early.
)
echo.
echo Next: if GitHub Actions opened, run:
echo   F1 Peak Elite Control Room - One Click v1
echo with:
echo   operation=full_safe_chain
echo   commit_outputs=true
echo   run_forecast_gate=false
echo.
pause
exit /b %EXITCODE%

