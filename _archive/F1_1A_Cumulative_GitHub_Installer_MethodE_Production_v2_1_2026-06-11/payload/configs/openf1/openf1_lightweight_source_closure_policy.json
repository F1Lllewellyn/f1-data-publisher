{
  "policy_name": "openf1_lightweight_source_closure",
  "created": "2026-06-10",
  "season": 2026,
  "purpose": "Capture lightweight OpenF1 source lanes and zero-lane diagnostics in GitHub so manual Colab catch-up is not required.",
  "source_hierarchy": [
    "existing GitHub latest artifact",
    "existing GitHub history path",
    "existing GitHub release/archive artifact",
    "local retained source artifacts",
    "targeted OpenF1 lightweight endpoint refresh"
  ],
  "default_year": 2026,
  "completed_session_only": true,
  "exclude_heavy_endpoints_by_default": [
    "car_data",
    "location"
  ],
  "required_lightweight_lanes": [
    "weather",
    "race_control",
    "intervals",
    "position",
    "stints",
    "pit",
    "starting_grid",
    "drivers"
  ],
  "opportunistic_lanes": [
    "team_radio"
  ],
  "endpoint_strategies": {
    "weather": [
      "session_key"
    ],
    "race_control": [
      "session_key"
    ],
    "intervals": [
      "session_key"
    ],
    "position": [
      "session_key",
      "meeting_key_fallback"
    ],
    "stints": [
      "session_key"
    ],
    "pit": [
      "race_or_sprint_session_key_only"
    ],
    "starting_grid": [
      "session_key"
    ],
    "drivers": [
      "session_key",
      "observed_driver_number_session_key"
    ],
    "team_radio": [
      "session_key_opportunistic"
    ]
  },
  "zero_lane_policy": {
    "hard_required_zero_rows": "retry_with_endpoint_specific_strategy_then_mark_needs_review",
    "opportunistic_zero_rows": "mark_source_limited_not_failure",
    "future_session_zero_rows": "mark_gated_not_missing"
  },
  "outputs": {
    "latest_dir": "latest/openf1_lightweight_source_closure",
    "history_dir": "history/openf1_lightweight_source_closure",
    "zip_name": "openf1_lightweight_source_closure.zip"
  },
  "timestamp_policy": "Use timezone-aware dt.datetime.now(dt.UTC) throughout retrieval scripts.",
  "no_drs_2026_assumption": true
}